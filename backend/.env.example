# Copy this to .env and fill in your own values

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/tempchat

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# How long login tokens stay valid (this is NOT the 72h data reset - that's separate)
JWT_EXPIRES_IN=7d

# Port the API + socket server runs on
PORT=5000

# Comma separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173

# How long messages & friendships live before auto-deleting, in seconds
# 259200 seconds = 72 hours. Change this if you want a shorter demo window (e.g. 300 for 5 min).
DATA_TTL_SECONDS=259200
